# Mandatory

# Required application database connection string.
HOPSHARE_DB_URL=postgres://user:pass@localhost:5432/hopshare?sslmode=disable


# Conditionally Required

# Enable email-driven flows such as signup verification and password reset email.
FEATURE_EMAIL=true

# Required when FEATURE_EMAIL=true and you want real outbound email delivery.
HOPSHARE_MAILGUN_API_KEY=replace_me


# Optional

# Server
HOPSHARE_ADDR=:8080
HOPSHARE_ENV=development

# Comma-separated email addresses with admin access.
HOPSHARE_ADMIN_EMAILS=admin@example.com

# IANA timezone used for rendered timestamps.
HOPSHARE_TIMEZONE=America/New_York

# Public URL and cookie behavior
HOPSHARE_PUBLIC_BASE_URL=http://localhost:8080
HOPSHARE_COOKIE_SECURE=true

# Feature flags
FEATURE_HOP_PICTURES=false

# Upload limits
HOPSHARE_AVATAR_IMAGE_SIZE=2097152

# Session settings
HOPSHARE_SESSION_ABSOLUTE_TTL=168h
HOPSHARE_SESSION_IDLE_TIMEOUT=24h

# Background workers
HOPSHARE_WORKERS_ENABLED=true
HOPSHARE_WORKER_POLL_INTERVAL=1m
HOPSHARE_WORKER_EXPIRE_HOPS_INTERVAL=1h
HOPSHARE_WORKER_SESSION_GC_INTERVAL=6h

# Mailgun email settings
HOPSHARE_MAILGUN_API_BASE_URL=https://api.mailgun.net
HOPSHARE_MAILGUN_DOMAIN=mg.example.com
HOPSHARE_MAILGUN_FROM_ADDRESS=HopShare <no-reply@example.com>
