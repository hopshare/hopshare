HOPSHARE_ADDR=:8080
HOPSHARE_DB_URL=postgres://user:pass@localhost:5432/hopshare?sslmode=disable
HOPSHARE_ENV=development
# Comma-separated usernames with Admin access (case-insensitive, spaces ignored).
# Leave empty to disable Admin routes for all users.
HOPSHARE_ADMINS=bill,simon
# IANA timezone used for rendered timestamps (stored DB times remain UTC).
# Examples: America/New_York, America/Chicago, Europe/London, UTC.
# Invalid values fail server startup.
HOPSHARE_TIMEZONE=America/New_York
# Feature flags.
# When FEATURE_EMAIL=false, signup does not require email verification and Mailgun is optional.
FEATURE_EMAIL=true
# When FEATURE_HOP_PICTURES=true, the Hop Details page shows the Pictures panel.
FEATURE_HOP_PICTURES=false
# Max avatar upload size in bytes (default 2097152 = 2 MB).
HOPSHARE_AVATAR_IMAGE_SIZE=2097152
# Public base URL used when generating email links.
HOPSHARE_PUBLIC_BASE_URL=http://localhost:8080
# Set to true in production (HTTPS) so auth/CSRF cookies are marked Secure.
# Set to false only for local HTTP dev/testing.
HOPSHARE_COOKIE_SECURE=true
# Session expiration controls.
# Absolute lifetime since login.
HOPSHARE_SESSION_ABSOLUTE_TTL=168h
# Idle timeout since last request activity.
HOPSHARE_SESSION_IDLE_TIMEOUT=24h
# Mailgun password-reset email settings.
HOPSHARE_MAILGUN_API_BASE_URL=https://api.mailgun.net
HOPSHARE_MAILGUN_DOMAIN=mg.example.com
HOPSHARE_MAILGUN_API_KEY=replace_me
HOPSHARE_MAILGUN_FROM_ADDRESS=HopShare <no-reply@example.com>
