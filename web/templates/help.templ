package templates

templ Help(userEmail *string) {
	@Base(helpPageContext(), userEmail, HelpBody())
}

templ HelpBody() {
	<div class="space-y-6">
		<div class="flex items-center justify-between gap-4">
			<h1 class="text-2xl font-bold text-slate-900">Help with hopShare</h1>
			<a class="text-sm font-semibold text-sky-700 underline hover:text-sky-800 md:hidden" href="/my-hopshare">Back to My hopShare</a>
		</div>
	</div>
}
