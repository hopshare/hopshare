func adminOpenActionModalCall(action string, orgID int64, hopID int64, title string, prompt string, confirmLabel string, confirmClass string) string {
	hopArg := "null"
	if hopID > 0 {
		hopArg = strconv.FormatInt(hopID, 10)
	}
	return "openActionModal(" +
		strconv.Quote(action) + ", " +
		strconv.FormatInt(orgID, 10) + ", " +
		hopArg + ", " +
		strconv.Quote(title) + ", " +
		strconv.Quote(prompt) + ", " +
		strconv.Quote(confirmLabel) + ", " +
		strconv.Quote(confirmClass) +
		")"
}

func adminOpenModerationActionModalCall(action string, reportID int64, title string, prompt string, confirmLabel string, confirmClass string) string {
	return "openModerationActionModal(" +
		strconv.Quote(action) + ", " +
		strconv.FormatInt(reportID, 10) + ", " +
		strconv.Quote(title) + ", " +
		strconv.Quote(prompt) + ", " +
		strconv.Quote(confirmLabel) + ", " +
		strconv.Quote(confirmClass) +
		")"
}

func adminOpenUserActionModalCall(action string, memberID int64, title string, prompt string, confirmLabel string, confirmClass string) string {
	return "openUserActionModal(" +
		strconv.Quote(action) + ", " +
		strconv.FormatInt(memberID, 10) + ", " +
		strconv.Quote(title) + ", " +
		strconv.Quote(prompt) + ", " +
		strconv.Quote(confirmLabel) + ", " +
		strconv.Quote(confirmClass) +
		")"
}

func adminOrganizationsTabURL(orgID int64, query string) string {
	base := "/admin?tab=organizations&org_id=" + strconv.FormatInt(orgID, 10)
	if strings.TrimSpace(query) != "" {
		base += "&q=" + url.QueryEscape(query)
	}
	return base
}

func adminUsersTabURL(memberID int64, query string) string {
	base := "/admin?tab=users&member_id=" + strconv.FormatInt(memberID, 10)
	if strings.TrimSpace(query) != "" {
		base += "&q=" + url.QueryEscape(query)
	}
	return base
}


func adminAuditExportURL(format string, filter types.AdminAuditFilter) string {
	values := url.Values{}
	values.Set("format", strings.TrimSpace(strings.ToLower(format)))
	if strings.TrimSpace(filter.Actor) != "" {
		values.Set("actor", strings.TrimSpace(filter.Actor))
	}
	if strings.TrimSpace(filter.StartDate) != "" {
		values.Set("start_date", strings.TrimSpace(filter.StartDate))
	}
	if strings.TrimSpace(filter.EndDate) != "" {
		values.Set("end_date", strings.TrimSpace(filter.EndDate))
	}
	if strings.TrimSpace(filter.Action) != "" {
		values.Set("action", strings.TrimSpace(filter.Action))
	}
	if strings.TrimSpace(filter.Organization) != "" {
		values.Set("organization", strings.TrimSpace(filter.Organization))
	}
	if strings.TrimSpace(filter.User) != "" {
		values.Set("user", strings.TrimSpace(filter.User))
	}
	if strings.TrimSpace(filter.Target) != "" {
		values.Set("target", strings.TrimSpace(filter.Target))
	}
	return "/admin/audit/export?" + values.Encode()
}

func adminAuditOrgSummary(event types.AdminAuditEventView) string {
	if event.OrganizationName != nil && strings.TrimSpace(*event.OrganizationName) != "" {
		if event.OrganizationID != nil {
			return *event.OrganizationName + " (#" + strconv.FormatInt(*event.OrganizationID, 10) + ")"
		}
		return *event.OrganizationName
	}
	if event.OrganizationID != nil {
		return "#" + strconv.FormatInt(*event.OrganizationID, 10)
	}
	return "-"
}

func adminAuditUserSummary(event types.AdminAuditEventView) string {
	if event.UserName != nil && strings.TrimSpace(*event.UserName) != "" {
		if event.UserEmail != nil && strings.TrimSpace(*event.UserEmail) != "" {
			return *event.UserName + " (" + *event.UserEmail + ")"
		}
		return *event.UserName
	}
	if event.UserEmail != nil && strings.TrimSpace(*event.UserEmail) != "" {
		return *event.UserEmail
	}
	if event.UserMemberID != nil {
		return "#" + strconv.FormatInt(*event.UserMemberID, 10)
	}
	return "-"
}

func adminAuditReason(reason *string) string {
	if reason == nil {
		return "-"
	}
	trimmed := strings.TrimSpace(*reason)
	if trimmed == "" {
		return "-"
	}
	return trimmed
}

func adminBoolString(v bool) string {
	if v {
		return "true"
	}
	return "false"
}

func adminTabLinkClass(active bool) string {
	base := "inline-flex items-center border-b-2 px-3 py-2 text-sm font-semibold transition "
	if active {
		return base + "border-sky-600 text-sky-700"
	}
	return base + "border-transparent text-slate-600 hover:border-slate-300 hover:text-slate-900"
}

func adminOrgResultLinkClass(active bool) string {
	base := "flex items-center justify-between gap-2 rounded-md px-2 py-1.5 text-sm transition "
	if active {
		return base + "bg-sky-100 text-sky-900"
	}
	return base + "text-slate-700 hover:bg-slate-50"
}

func adminEnabledBadgeClass(enabled bool) string {
	base := "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold "
	if enabled {
		return base + "bg-emerald-100 text-emerald-800"
	}
	return base + "bg-slate-200 text-slate-700"
}

func adminVerifiedBadgeClass(verified bool) string {
	base := "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold "
	if verified {
		return base + "bg-emerald-100 text-emerald-800"
	}
	return base + "bg-amber-100 text-amber-800"
}
